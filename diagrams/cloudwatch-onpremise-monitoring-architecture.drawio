<mxfile host="app.diagrams.net">
  <diagram name="Architecture" id="cw-onprem-arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" background="#faf9f5">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="オンプレミスデバイス CloudWatch 監視" style="text;html=1;fontSize=18;fontStyle=1;fontFamily=Helvetica;fontColor=#141413;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- On-Premises Group -->
        <mxCell id="onprem-group" value="On-Premises" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#141413;dashed=1;strokeWidth=1;fontSize=14;fontStyle=1;fontFamily=Helvetica;fontColor=#141413;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="350" height="310" as="geometry"/>
        </mxCell>

        <!-- Raspberry Pi -->
        <mxCell id="rpi-icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;fontFamily=Helvetica;shape=mxgraph.aws4.traditional_server;fillColor=#ED7100;" vertex="1" parent="1">
          <mxGeometry x="100" y="140" width="50" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="rpi-label" value="Raspberry Pi&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;NAS&lt;/font&gt;" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#141413;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="70" y="222" width="110" height="35" as="geometry"/>
        </mxCell>

        <!-- MacBook -->
        <mxCell id="mac-icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;fontFamily=Helvetica;shape=mxgraph.aws4.traditional_server;fillColor=#ED7100;" vertex="1" parent="1">
          <mxGeometry x="270" y="140" width="50" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="mac-label" value="MacBook Air M3&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;検証用&lt;/font&gt;" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#141413;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="235" y="222" width="120" height="35" as="geometry"/>
        </mxCell>

        <!-- CW Agent boxes -->
        <mxCell id="agent-rpi" value="CloudWatch Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontFamily=Helvetica;fontColor=#141413;" vertex="1" parent="1">
          <mxGeometry x="70" y="270" width="110" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="agent-mac" value="CloudWatch Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontFamily=Helvetica;fontColor=#141413;" vertex="1" parent="1">
          <mxGeometry x="240" y="270" width="110" height="30" as="geometry"/>
        </mxCell>

        <!-- Note: metrics -->
        <mxCell id="note-metrics" value="収集メトリクス:&lt;br&gt;CPU / メモリ / ディスク&lt;br&gt;ディスクIO / ネットワーク / スワップ&lt;br&gt;（60秒間隔）" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontFamily=Helvetica;fontColor=#141413;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="note-metrics-conn" style="endArrow=none;dashed=1;strokeColor=#d6b656;fontFamily=Helvetica;" edge="1" source="note-metrics" target="agent-rpi" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- AWS Cloud Group -->
        <mxCell id="aws-cloud" value="" style="shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;verticalAlign=top;align=left;spacingLeft=30;fillColor=none;strokeColor=#AAB7B8;dashed=0;fontStyle=1;fontSize=14;fontFamily=Helvetica;fontColor=#232F3E;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="80" width="520" height="420" as="geometry"/>
        </mxCell>

        <!-- Region Group -->
        <mxCell id="region" value="ap-northeast-1" style="shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_region;verticalAlign=top;align=left;spacingLeft=30;fillColor=none;strokeColor=#00A4A6;dashed=1;fontStyle=1;fontSize=12;fontFamily=Helvetica;fontColor=#00A4A6;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="110" width="480" height="370" as="geometry"/>
        </mxCell>

        <!-- IAM (top-right area) -->
        <mxCell id="iam-icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;fontFamily=Helvetica;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management;fillColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="860" y="150" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="iam-label" value="IAM User&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;CloudWatchAgent&lt;br&gt;ServerPolicy&lt;/font&gt;" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#141413;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="835" y="205" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- CloudWatch (center) -->
        <mxCell id="cw-icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;fontFamily=Helvetica;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch;fillColor=#E7157B;" vertex="1" parent="1">
          <mxGeometry x="580" y="260" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="cw-label" value="CloudWatch&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;CWAgent 名前空間&lt;/font&gt;" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#141413;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="545" y="315" width="120" height="35" as="geometry"/>
        </mxCell>

        <!-- CloudWatch Alarm -->
        <mxCell id="alarm-icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;fontFamily=Helvetica;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch;fillColor=#E7157B;" vertex="1" parent="1">
          <mxGeometry x="740" y="260" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="alarm-label" value="CloudWatch&lt;br&gt;Alarm" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#141413;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="720" y="315" width="90" height="30" as="geometry"/>
        </mxCell>

        <!-- SNS -->
        <mxCell id="sns-icon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;fontFamily=Helvetica;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sns;fillColor=#E7157B;" vertex="1" parent="1">
          <mxGeometry x="890" y="260" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="sns-label" value="SNS&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Email通知&lt;/font&gt;" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#141413;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="880" y="315" width="70" height="35" as="geometry"/>
        </mxCell>

        <!-- Note: IAM minimum privilege -->
        <mxCell id="note-iam" value="最小権限:&lt;br&gt;CloudWatchAgentServerPolicy&lt;br&gt;のみアタッチ" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontFamily=Helvetica;fontColor=#141413;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="810" y="400" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="note-iam-conn" style="endArrow=none;dashed=1;strokeColor=#d6b656;fontFamily=Helvetica;" edge="1" source="note-iam" target="iam-icon" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: RPi Agent -> CloudWatch (main flow) -->
        <mxCell id="arrow-rpi-cw" value="① メトリクス送信&lt;br&gt;（60秒間隔）" style="endArrow=block;endFill=1;strokeColor=#141413;strokeWidth=2;fontFamily=Helvetica;fontSize=10;fontColor=#141413;labelBackgroundColor=#faf9f5;html=1;" edge="1" source="agent-rpi" target="cw-icon" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: Mac Agent -> CloudWatch (dashed, verification) -->
        <mxCell id="arrow-mac-cw" value="" style="endArrow=block;endFill=1;strokeColor=#141413;strokeWidth=1;dashed=1;fontFamily=Helvetica;fontSize=10;fontColor=#141413;html=1;" edge="1" source="agent-mac" target="cw-icon" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: Agents -> IAM (auth, upward) -->
        <mxCell id="arrow-mac-iam" value="認証" style="endArrow=block;endFill=1;strokeColor=#DD344C;strokeWidth=1;dashed=1;fontFamily=Helvetica;fontSize=10;fontColor=#DD344C;labelBackgroundColor=#faf9f5;html=1;" edge="1" source="agent-mac" target="iam-icon" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: CW -> Alarm -->
        <mxCell id="arrow-cw-alarm" value="② 閾値評価" style="endArrow=block;endFill=1;strokeColor=#141413;strokeWidth=2;fontFamily=Helvetica;fontSize=10;fontColor=#141413;labelBackgroundColor=#faf9f5;html=1;" edge="1" source="cw-icon" target="alarm-icon" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: Alarm -> SNS -->
        <mxCell id="arrow-alarm-sns" value="③ 通知" style="endArrow=block;endFill=1;strokeColor=#141413;strokeWidth=2;fontFamily=Helvetica;fontSize=10;fontColor=#141413;labelBackgroundColor=#faf9f5;html=1;" edge="1" source="alarm-icon" target="sns-icon" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
