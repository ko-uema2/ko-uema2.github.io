<mxfile host="app.diagrams.net">
  <diagram name="Architecture" id="arch">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1200" pageHeight="900" background="#faf9f5">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ========== メインフロー: Webhook処理 ========== -->

        <!-- Google Drive (トリガー元) -->
        <mxCell id="gdrive" value="Google Drive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4285F4;fillOpacity=15;strokeColor=#4285F4;strokeWidth=1.5;fontColor=#141413;fontSize=13;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="120" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- API Gateway -->
        <mxCell id="apigw" value="API Gateway" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#E7157B;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.api_gateway;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="280" y="110" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- webhookHandler (主役) -->
        <mxCell id="wh" value="webhookHandler" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#ED7100;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.lambda;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="500" y="105" width="70" height="70" as="geometry" />
        </mxCell>

        <!-- webhookHandlerの接続先（右側、縦に並べる） -->

        <!-- DynamoDB -->
        <mxCell id="ddb" value="DynamoDB" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#C925D1;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.dynamodb;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="720" y="30" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Secrets Manager -->
        <mxCell id="sm" value="Secrets&#xa;Manager" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#DD344C;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.secrets_manager;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="720" y="130" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- SES -->
        <mxCell id="ses" value="Amazon SES&#xa;(エラー通知)" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#E7157B;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.sns;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="720" y="230" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- webhookHandlerの接続先（下部） -->

        <!-- Google Drive (CSV取得先) -->
        <mxCell id="gdrive2" value="Google Drive&#xa;(CSV取得)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4285F4;fillOpacity=15;strokeColor=#4285F4;strokeWidth=1;fontColor=#141413;fontSize=11;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="310" width="120" height="45" as="geometry" />
        </mxCell>

        <!-- Google Sheets -->
        <mxCell id="gsheets" value="Google Sheets&#xa;(集計書き込み)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F9D58;fillOpacity=15;strokeColor=#0F9D58;strokeWidth=1;fontColor=#141413;fontSize=11;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="310" width="130" height="45" as="geometry" />
        </mxCell>

        <!-- EventBridge + renewal（右上） -->

        <mxCell id="eb" value="EventBridge" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#E7157B;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.eventbridge;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="900" y="40" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="renew" value="renewal&#xa;Handler" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#ED7100;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.lambda;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1020" y="45" width="45" height="45" as="geometry" />
        </mxCell>

        <!-- ========== 区切り線 ========== -->
        <mxCell id="separator" value="" style="line;strokeWidth=1;strokeColor=#b0aea5;dashed=1;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="430" width="1040" height="10" as="geometry" />
        </mxCell>

        <!-- ========== 管理API群（区切り線の下、独立セクション） ========== -->

        <mxCell id="mgmt_label" value="管理用API（IAM認証で別途呼び出し）" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontColor=#b0aea5;fontSize=12;fontFamily=Helvetica;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="450" width="260" height="30" as="geometry" />
        </mxCell>

        <mxCell id="sub" value="subscribe&#xa;Handler" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#ED7100;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.lambda;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="45" height="45" as="geometry" />
        </mxCell>

        <mxCell id="unsub" value="unsubscribe&#xa;Handler" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#ED7100;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.lambda;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="160" y="480" width="45" height="45" as="geometry" />
        </mxCell>

        <mxCell id="stat" value="status&#xa;Handler" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#ED7100;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.lambda;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="280" y="480" width="45" height="45" as="geometry" />
        </mxCell>

        <mxCell id="cfg" value="config&#xa;Handler" style="sketch=0;outlineConnect=0;fontColor=#141413;gradientColor=none;strokeColor=#ffffff;fillColor=#ED7100;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.lambda;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="400" y="480" width="45" height="45" as="geometry" />
        </mxCell>

        <!-- ========== エッジ: メインフローのみ ========== -->

        <!-- Google Drive → API Gateway -->
        <mxCell id="e1" value="Push Notification" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#141413;strokeWidth=2;fontColor=#141413;fontSize=11;fontFamily=Helvetica;labelBackgroundColor=#faf9f5;endArrow=block;endFill=1;" edge="1" parent="1" source="gdrive" target="apigw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- API Gateway → webhookHandler -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E7157B;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="apigw" target="wh">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- webhookHandler → Google Drive (CSV取得) -->
        <mxCell id="e3" value="CSV取得" style="rounded=1;strokeColor=#4285F4;strokeWidth=1.5;fontColor=#141413;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#faf9f5;endArrow=block;endFill=1;" edge="1" parent="1" source="wh" target="gdrive2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- webhookHandler → Google Sheets -->
        <mxCell id="e4" value="集計書き込み" style="rounded=1;strokeColor=#0F9D58;strokeWidth=1.5;fontColor=#141413;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#faf9f5;endArrow=block;endFill=1;" edge="1" parent="1" source="wh" target="gsheets">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- webhookHandler → DynamoDB -->
        <mxCell id="e5" style="rounded=1;strokeColor=#b0aea5;strokeWidth=1;dashed=1;endArrow=block;endFill=1;" edge="1" parent="1" source="wh" target="ddb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- webhookHandler → Secrets Manager -->
        <mxCell id="e6" style="rounded=1;strokeColor=#b0aea5;strokeWidth=1;dashed=1;endArrow=block;endFill=1;" edge="1" parent="1" source="wh" target="sm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- webhookHandler → SES -->
        <mxCell id="e7" style="rounded=1;strokeColor=#b0aea5;strokeWidth=1;dashed=1;endArrow=block;endFill=1;" edge="1" parent="1" source="wh" target="ses">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- EventBridge → renewalHandler -->
        <mxCell id="e8" value="12h更新" style="rounded=1;strokeColor=#E7157B;strokeWidth=1.5;fontColor=#141413;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#faf9f5;endArrow=block;endFill=1;" edge="1" parent="1" source="eb" target="renew">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
