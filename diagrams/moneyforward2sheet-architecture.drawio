        <mxCell id="e1" value="Push Notification" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#141413;strokeWidth=1.5;fontColor=#141413;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#faf9f5;endArrow=block;endFill=1;" edge="1" parent="1" source="gdrive" target="apigw">
